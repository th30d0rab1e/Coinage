cp.fetchProducts = async function () {
    try {
       let data = await getApiCall("https://api.coinbase.com/api/v3/brokerage/products");
       //https://api.exchange.coinbase.com/products
       console.log(data);

       let array = [];

       data.forEach(element => {
        if (element.quote_currency == "USD") {
            let active = false;
                if (element.trading_disabled) {
                    active = true;
                }
            array.push({
                id: element.id
                , base_min_size: element.base_min_size
                , base_max_size: element.base_max_size
                , quote_increment: element.quote_increment
                , base_increment: element.base_increment
                , min_market_funds: element.min_market_funds
                , max_market_funds: element.max_market_funds
                , trading_disabled: active
                , status: element.status_message
                , display_name: element.display_name
                , post_only: element.post_only
                , cancel_only: element.cancel_only
                , System: 'Coinbase'
            })
        }
    });
    return array;

    } catch (error) {
        console.log("fetchProducts", error);
    }
}

